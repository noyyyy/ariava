{
  "name": "@ariava/pi-extension",
  "version": "0.1.8",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
