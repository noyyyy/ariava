{
  "name": "ariava",
  "version": "0.1.8",
  "description": "Live Your Life. Your Agents Stay Close.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/noyyyy/ariava",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noyyyy/ariava.git"
  },
  "bugs": {
    "url": "https://github.com/noyyyy/ariava/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "ariava": "apps/bridge/dist/public-cli.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "apps/bridge/dist",
    "packages/protocol/dist",
    "packages/shared-utils/dist",
    "extensions/pi/bundle"
  ],
  "workspaces": [
    "apps/bridge",
    "extensions/pi",
    "packages/*"
  ],
  "scripts": {
    "boundary:check": "node ./scripts/assert-repository-boundaries.mjs --mode public-candidate --root .",
    "build": "bun run build:protocol && bun run build:shared-utils && bun run build:bridge && bun run build:pi-bundle",
    "build:protocol": "bun run ./scripts/build-public-package.mjs protocol",
    "build:shared-utils": "bun run ./scripts/build-public-package.mjs shared-utils",
    "build:bridge": "node ./scripts/build-bridge.mjs",
    "dev:init": "bun run ./apps/bridge/src/dev-profile-cli.ts init",
    "dev:bridge": "bun run ./apps/bridge/src/dev-profile-cli.ts bridge",
    "dev:pi": "bun run ./apps/bridge/src/dev-profile-cli.ts pi",
    "dev:status": "bun run ./apps/bridge/src/dev-profile-cli.ts status",
    "version:bump": "node ./scripts/bump-version.mjs",
    "release:prepare": "./scripts/publish-npm-safe.sh --prepare",
    "build:pi-bundle": "bun run --cwd extensions/pi build && node ./scripts/build-pi-release-bundle.mjs",
    "package:assert": "node ./scripts/package-assert.mjs",
    "prepublishOnly": "node ./scripts/assert-publication-readme.mjs",
    "test": "NODE_ENV=test bun test ./scripts ./packages/protocol/test ./packages/shared-utils/test ./apps/bridge/test && bun run --cwd extensions/pi test",
    "test:bridge-crypto:node": "node --test ./apps/bridge/test-node/*.test.mjs",
    "verify": "bun run boundary:check && bun run build && bun run test:bridge-crypto:node && bun run --cwd extensions/pi typecheck && bun run test && bun run package:assert",
    "dev:setup": "bun run ./apps/bridge/src/dev-profile-cli.ts setup"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  }
}
